#include <WiFi.h>
#include <WebServer.h>
#include <ESP32Servo.h>

#define IN1 14
#define IN2 27
#define IN3 26
#define IN4 25

#define TRIG_PIN 5
#define ECHO_PIN 18
#define SERVO_PIN 13

#define MAP_SIZE 20
#define CELL_SIZE 10

int mapGrid[MAP_SIZE][MAP_SIZE];

float robotX = MAP_SIZE / 2;
float robotY = MAP_SIZE / 2;
float robotAngle = 0;

Servo scanner;
WebServer server(80);

const char* ssid = "SLAM_BOT";
const char* password = "12345678";

void forward() {
  digitalWrite(IN1, HIGH);
  digitalWrite(IN2, LOW);
  digitalWrite(IN3, HIGH);
  digitalWrite(IN4, LOW);
}

void stopMotors() {
  digitalWrite(IN1, LOW);
  digitalWrite(IN2, LOW);
  digitalWrite(IN3, LOW);
  digitalWrite(IN4, LOW);
}

long getDistance() {
  digitalWrite(TRIG_PIN, LOW);
  delayMicroseconds(2);
  digitalWrite(TRIG_PIN, HIGH);
  delayMicroseconds(10);
  digitalWrite(TRIG_PIN, LOW);
  long duration = pulseIn(ECHO_PIN, HIGH, 30000);
  if (duration == 0) return -1;
  return duration * 0.034 / 2;
}

void updateMap(float angleDeg, float distance) {
  if (distance <= 0 || distance > 200) return;
  float angleRad = radians(angleDeg) + robotAngle;
  float obsX = robotX + (distance / CELL_SIZE) * cos(angleRad);
  float obsY = robotY + (distance / CELL_SIZE) * sin(angleRad);
  int gx = (int)obsX;
  int gy = (int)obsY;
  if (gx >= 0 && gx < MAP_SIZE && gy >= 0 && gy < MAP_SIZE) {
    mapGrid[gx][gy] = 1;
  }
}

void scanEnvironment() {
  for (int angle = 30; angle <= 150; angle += 15) {
    scanner.write(angle);
    delay(80);
    long d = getDistance();
    updateMap(angle - 90, d);
  }
}

void moveForwardStep() {
  forward();
  delay(400);
  stopMotors();
  robotX += cos(robotAngle);
  robotY += sin(robotAngle);
}

String mapHTML() {
  String html = "<html><body><h3>SLAM MAP</h3><table border='1'>";
  for (int y = 0; y < MAP_SIZE; y++) {
    html += "<tr>";
    for (int x = 0; x < MAP_SIZE; x++) {
      if ((int)robotX == x && (int)robotY == y)
        html += "<td style='width:15px;height:15px;background:blue'></td>";
      else if (mapGrid[x][y] == 1)
        html += "<td style='background:black'></td>";
      else
        html += "<td></td>";
    }
    html += "</tr>";
  }
  html += "</table></body></html>";
  return html;
}

void setup() {
  pinMode(IN1, OUTPUT);
  pinMode(IN2, OUTPUT);
  pinMode(IN3, OUTPUT);
  pinMode(IN4, OUTPUT);
  pinMode(TRIG_PIN, OUTPUT);
  pinMode(ECHO_PIN, INPUT);

  scanner.attach(SERVO_PIN);
  scanner.write(90);

  Serial.begin(115200);

  WiFi.softAP(ssid, password);

  server.on("/", []() {
    server.send(200, "text/html", mapHTML());
  });

  server.begin();
}

void loop() {
  scanEnvironment();
  moveForwardStep();
  server.handleClient();
  delay(200);
}